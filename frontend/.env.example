# Backend API base URL
VITE_API_URL=http://localhost:3001

# ── Web3Auth (Google / social / email login front door) ──
# Client ID from your project at https://dashboard.web3auth.io — the Google/social/email button
# in OnboardingPage throws until this is set.
VITE_WEB3AUTH_CLIENT_ID=
# Optional — defaults to sapphire_mainnet. Use sapphire_devnet while testing.
VITE_WEB3AUTH_NETWORK=

# ── smart-account-kit (OpenZeppelin Smart Accounts) ──
# Network the kit talks to.
VITE_RPC_URL=https://soroban-testnet.stellar.org
VITE_NETWORK_PASSPHRASE=Test SDF Network ; September 2015
# Pre-deployed shared testnet contracts (Path A). For mainnet, deploy your own.
VITE_ACCOUNT_WASM_HASH=a12e8fa9621efd20315753bd4007d974390e31fbcb4a7ddc4dd0a0dec728bf2e
VITE_WEBAUTHN_VERIFIER_ADDRESS=CBSHV66WG7UV6FQVUTB67P3DZUEJ2KJ5X6JKQH5MFRAAFNFJUAJVXJYV
VITE_ED25519_VERIFIER_ADDRESS=CDGMOL3BP6Y6LYOXXTRNXBNJ2SLNTQ47BGG3LOS2OBBE657E3NYCN54B
# Backend relayer proxy for gasless submission (RPC fallback if left blank).
VITE_RELAYER_URL=http://localhost:3001/wallet/relay

# Shielded pool contract (same as backend STELLAR_CONTRACT_ID). Used as a fallback for any
# asset below that doesn't have its own VITE_*_POOL_CONTRACT_ID set.
VITE_ESCROW_CONTRACT_ID=

# Per-asset shielded pool contract ids (each asset has its own on-chain pool/tree — see
# backend/services/pools.ts). Required once you have more than one asset, since they can't
# all share VITE_ESCROW_CONTRACT_ID.
VITE_XLM_POOL_CONTRACT_ID=
VITE_USDC_POOL_CONTRACT_ID=

# Stellar Asset Contract (SAC) addresses for supported tokens
VITE_XLM_SAC=
VITE_USDC_SAC=
VITE_NGNC_SAC=

# DEPRECATED — legacy passkey-kit wallet wasm (superseded by VITE_ACCOUNT_WASM_HASH)
VITE_WALLET_WASM_HASH=
