# ── Database (Neon Postgres) ──
# Used by prisma.config.ts for migrate/generate. Use the DIRECT (non-pooled) Neon URL,
# sslmode=require, no channel_binding.
NEON_CONNECTION_STRING=
# Used by the Prisma client at runtime (via @prisma/adapter-pg). Usually the same value.
DATABASE_URL=

PORT=3001
NODE_ENV=development
# Comma-separated allowlist, e.g. https://shieldpass-lite.vercel.app — unset allows any origin
# (fine for local dev only).
CORS_ORIGIN=

# ── Firebase Auth (Google login verification) ──
# From the Firebase console: Project Settings > Service accounts > Generate new private key.
# FIREBASE_PROJECT_ID must match the frontend's VITE_FIREBASE_PROJECT_ID. The downloaded JSON's
# private_key has literal "\n" sequences — paste it as one line, they're un-escaped at runtime.
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# ── Stellar / Soroban ──
STELLAR_RPC_URL=https://soroban-testnet.stellar.org
STELLAR_NETWORK_PASSPHRASE=Test SDF Network ; September 2015
STELLAR_CONTRACT_ID=
STELLAR_RELAYER_SECRET=
XLM_SAC_ADDRESS=
USDC_SAC_ADDRESS=
USDC_POOL_CONTRACT_ID=

# ── OpenZeppelin Relayer Channels (gasless submission) ──
CHANNELS_URL=
CHANNELS_API_KEY=

# ── Onboarding faucet ──
FAUCET_NOTE_AMOUNT=1000000000
FAUCET_NOTE_ASSET=XLM
# Comma-separated list of tokens to seed for new wallets on faucet fallback (public seed path).
SEED_TOKENS=

# ── Swap / pricing ──
FIAT_MODE=
SWAP_PRICE_MODE=
SWAP_RATES=
SWAP_DEFAULT_RATE=
SWAP_XLM_FALLBACK_NGN=
SWAP_USDC_FALLBACK_NGN=
SWAP_PRICE_TTL_MS=
SWAP_PRICE_TIMEOUT_MS=
COINGECKO_API_KEY=
TIER2_THRESHOLD_NAIRA=

# ── Fiat payout (Lenco) ──
LENCO_API_URL=
LENCO_API_KEY=
LENCO_ACCOUNT_ID=
PAYSTACK_SECRET_KEY=
